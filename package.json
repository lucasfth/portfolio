{
  "name": "portfolio",
  "homepage": "https://lucashanson.dk",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@heroui/navbar": "^2.2.9",
    "@heroui/react": "^2.7.9",
    "@shadcn/ui": "^0.0.4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "next": "^15.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.1",
    "web-vitals": "^5.0.2"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && bun run generate-rss",
    "start": "next start",
    "generate-rss": "bun scripts/generateRSS.js",
    "normalize-extensions": "find out/images -type f -name '*.JPG' -exec bash -c 'echo Converting \\\"$1\\\" to lowercase; mv \"$1\" \"${1%.JPG}.jpg\"' _ {} \\; && echo 'Done normalizing extensions'",
    "normalize-markdown": "find out/content -type f -name '*.md' -exec sed -i '' 's/\\.JPG/\\.jpg/g' {} \\;",
    "predeploy": "bun run build && bun run normalize-extensions && bun run normalize-markdown",
    "deploy": "gh-pages -d out",
    "deploy-test": "bun run predeploy && echo 'Test deployment completed. Would deploy out/ directory to GitHub Pages.'",
    "test": "jest",
    "lint": "next lint"
  },
  "eslintConfig": {
    "extends": [
      "next/core-web-vitals"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.1",
    "gh-pages": "^6.3.0",
    "typescript": "^5.7.3"
  }
}
